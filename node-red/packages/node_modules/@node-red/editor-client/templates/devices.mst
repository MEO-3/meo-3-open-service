<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>MEO Devices</title>
<link rel="icon" type="image/png" href="{{{ page.favicon }}}">
<link rel="mask-icon" href="{{{ page.tabicon.icon }}}" color="{{ page.tabicon.colour }}">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="red/meo/meo-page.css?v={{ cacheBuster }}">
</head>
<body class="meo-page" spellcheck="false">
<div class="meo-page-frame">
    <main class="container min-vh-100 d-flex flex-column align-items-center justify-content-center text-center px-4 py-5">
        <section class="d-flex flex-column align-items-center" aria-labelledby="meo-devices-title">
            <div class="meo-error-code mb-4" aria-hidden="true">404</div>
            <h1 id="meo-devices-title" class="meo-empty-title mb-3">Page Not Found</h1>
            <p class="meo-empty-copy mb-0">
                The destination you are trying to reach does not exist or has been moved.
            </p>
            <a class="btn btn-meo-primary mt-5 px-4 py-2" href="./">Return to Dashboard</a>
        </section>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
